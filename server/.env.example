#What it does: A template that lists every environment variable your project needs, with placeholder values instead of real ones. This one is committed to GitHub.

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/petpals

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── Supabase (media storage) ──────────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── OpenAI API (AI matcher) ────────────────────────
OPENAI_API_KEY=your_anthropic_api_key_here

# ── Client ────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api/v1
